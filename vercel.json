{
  "version": 2,
  "builds": [
    {
      "src": "api/pair.mjs",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "maxLambdaSize": "100mb",
        "maxDuration": 60,
        "memory": 1024
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/pair",
      "dest": "/api/pair.mjs"
    },
    {
      "src": "/nexus_drill.mp3",
      "dest": "/public/nexus_drill.mp3"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
